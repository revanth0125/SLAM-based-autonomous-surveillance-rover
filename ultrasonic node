#!/usr/bin/env python3
"""
ultrasonic_node.py
Publishes sensor_msgs/Range from an HC-SR04-style ultrasonic sensor
(TRIG=GPIO18, ECHO=GPIO22) for use as an extra close-range obstacle
input in the Nav2 costmap, alongside the YDLidar X2 scan.

IMPORTANT WIRING NOTE: the ECHO pin outputs 5V, but Pi GPIO inputs are
3.3V-only. Use a voltage divider (e.g. 1k + 2k resistors) between ECHO
and GPIO22, or a proper logic-level shifter, or you will damage the
Pi's GPIO.

Requires: pip install gpiozero rpi-lgpio
"""

import rclpy
from rclpy.node import Node
from sensor_msgs.msg import Range

from gpiozero import DistanceSensor, Device
from gpiozero.pins.lgpio import LGPIOFactory

Device.pin_factory = LGPIOFactory()


class UltrasonicNode(Node):
    def __init__(self):
        super().__init__('ultrasonic_node')
        self.sensor = DistanceSensor(echo=22, trigger=18, max_distance=4.0)
        self.pub = self.create_publisher(Range, '/ultrasonic/range', 10)
        self.create_timer(0.1, self.publish_range)  # 10 Hz

    def publish_range(self):
        msg = Range()
        msg.header.stamp = self.get_clock().now().to_msg()
        msg.header.frame_id = 'ultrasonic_link'
        msg.radiation_type = Range.ULTRASOUND
        msg.field_of_view = 0.26  # ~15 degrees, typical HC-SR04 cone
        msg.min_range = 0.02
        msg.max_range = 4.0
        # gpiozero's DistanceSensor.distance is already in metres,
        # scaled 0 .. max_distance
        msg.range = self.sensor.distance
        self.pub.publish(msg)


def main(args=None):
    rclpy.init(args=args)
    node = UltrasonicNode()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == '__main__':
    main()
